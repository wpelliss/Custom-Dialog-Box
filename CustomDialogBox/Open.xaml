<Window x:Class="CustomDialogBox.Open"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:CustomDialogBox"
        Title="Ouvrir"
        Height="540" Width="860"
        MinHeight="320" MinWidth="560"
        WindowStartupLocation="CenterOwner">

    <!-- ═══════════════════════════ RESSOURCES ═══════════════════════════ -->
    <Window.Resources>

        <!-- Template hiérarchique pour l'arbre de navigation -->
        <HierarchicalDataTemplate DataType="{x:Type local:FileSystemNodeViewModel}"
                                   ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal">
                <Image Source="{Binding Icon}" Width="16" Height="16" Margin="0,0,4,0"
                       VerticalAlignment="Center"
                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
            </StackPanel>
        </HierarchicalDataTemplate>

        <!-- Binding TwoWay IsExpanded / IsSelected sur les TreeViewItem -->
        <Style TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
        </Style>

        <!-- Style bouton breadcrumb (apparence lien texte) -->
        <Style x:Key="BreadcrumbBtn" TargetType="Button">
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="BorderBrush"  Value="Transparent"/>
            <Setter Property="Padding"      Value="3,1"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Foreground"   Value="{DynamicResource {x:Static SystemColors.HotTrackBrushKey}}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="2" Padding="{TemplateBinding Padding}">
                            <TextBlock x:Name="txt"
                                       Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="txt" Property="TextDecorations" Value="Underline"/>
                                <Setter Property="Background"
                                        Value="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background"
                                        Value="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style item Quick Access (ListBox) -->
        <Style x:Key="QuickAccessItem" TargetType="ListBoxItem">
            <Setter Property="Padding"  Value="6,3"/>
            <Setter Property="Cursor"   Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bdr" CornerRadius="3"
                                Background="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <TextBlock Text="{Binding Label}" FontSize="12"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background"
                                        Value="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bdr" Property="Background"
                                        Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- ═══════════════════════════ RACCOURCIS ════════════════════════════ -->
    <Window.InputBindings>
        <KeyBinding Key="F5"   Command="{Binding RefreshCommand}"/>
        <KeyBinding Key="Back" Command="{Binding GoUpCommand}"/>
    </Window.InputBindings>

    <!-- ═══════════════════════════ LAYOUT PRINCIPAL ══════════════════════ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="34"/>    <!-- 0 : barre adresse / breadcrumb -->
            <RowDefinition Height="*"/>     <!-- 1 : contenu principal          -->
            <RowDefinition Height="4"/>     <!-- 2 : séparateur                 -->
            <RowDefinition Height="Auto"/>  <!-- 3 : barre inférieure           -->
        </Grid.RowDefinitions>

        <!-- ─────────────── ROW 0 : Barre adresse + Recherche ─────────── -->
        <Grid Grid.Row="0" Margin="4,3,4,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="155"/>
            </Grid.ColumnDefinitions>

            <!-- Breadcrumb (mode normal) — clic pour basculer en saisie directe -->
            <Border Grid.Column="0" x:Name="breadcrumbBorder"
                    BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                    BorderThickness="1" CornerRadius="3"
                    Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                    Padding="2,0" Margin="0,0,4,0"
                    MouseDown="BreadcrumbBorder_MouseDown"
                    Cursor="IBeam">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              Focusable="False">
                    <ItemsControl ItemsSource="{Binding Breadcrumbs}" VerticalAlignment="Center">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type local:NavItem}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="{Binding Label}"
                                            Style="{StaticResource BreadcrumbBtn}"
                                            Command="{Binding DataContext.NavigateCommand,
                                                      RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding FullPath}"/>
                                    <TextBlock Text=" ›" VerticalAlignment="Center"
                                               Foreground="Gray" Margin="0,0,2,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- TextBox saisie directe (mode édition, caché par défaut) -->
            <TextBox Grid.Column="0" x:Name="addressBox"
                     Visibility="Collapsed" Margin="0,0,4,0"
                     VerticalContentAlignment="Center" Padding="4,0"
                     KeyDown="AddressBox_KeyDown"
                     LostFocus="AddressBox_LostFocus"/>

            <!-- Zone de recherche — Ctrl+F pour y aller, Escape pour effacer -->
            <Border Grid.Column="1"
                    BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                    BorderThickness="1" CornerRadius="3"
                    Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                    Padding="0">
                <Grid>
                    <TextBlock Text="Rechercher..."
                               Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                               VerticalAlignment="Center" Margin="7,0,0,0"
                               IsHitTestVisible="False" FontStyle="Italic" FontSize="11">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FilterText}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding FilterText}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBox x:Name="searchBox"
                             Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                             BorderThickness="0" Background="Transparent"
                             VerticalContentAlignment="Center" Padding="6,0"
                             PreviewKeyDown="SearchBox_PreviewKeyDown"/>
                </Grid>
            </Border>
        </Grid>

        <!-- ─────────────── ROW 1 : Panneau principal ──────────────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" MinWidth="100"/>  <!-- Accès rapide + arbre -->
                <ColumnDefinition Width="4"/>                   <!-- GridSplitter         -->
                <ColumnDefinition Width="*"   MinWidth="160"/>  <!-- Liste fichiers        -->
            </Grid.ColumnDefinitions>

            <!-- ── Colonne gauche : Accès rapide + Arbre ── -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>           <!-- Label Accès rapide   -->
                    <RowDefinition Height="Auto" MaxHeight="155"/>  <!-- ListBox QA    -->
                    <RowDefinition Height="6"/>              <!-- Séparateur           -->
                    <RowDefinition Height="Auto"/>           <!-- Label Ordinateur     -->
                    <RowDefinition Height="*"/>              <!-- TreeView             -->
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Accès rapide"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="Gray"
                           Margin="6,4,4,2"/>

                <ListBox Grid.Row="1"
                         ItemsSource="{Binding QuickAccess}"
                         ItemContainerStyle="{StaticResource QuickAccessItem}"
                         SelectionChanged="QuickAccess_SelectionChanged"
                         BorderThickness="0"
                         Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>

                <Separator Grid.Row="2" Margin="6,0"/>

                <TextBlock Grid.Row="3"
                           Text="Ordinateur"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="Gray"
                           Margin="6,2,4,2"/>

                <TreeView Grid.Row="4"
                          x:Name="treeViewFolders"
                          ItemsSource="{Binding Drives}"
                          SelectedItemChanged="TreeView_SelectedItemChanged"
                          VirtualizingStackPanel.IsVirtualizing="True"
                          VirtualizingStackPanel.VirtualizationMode="Recycling"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          BorderThickness="0"
                          Margin="0,0,0,4"/>
            </Grid>

            <!-- ── GridSplitter ── -->
            <GridSplitter Grid.Column="1"
                          Width="4"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          ResizeBehavior="PreviousAndNext"
                          ResizeDirection="Columns"
                          Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"/>

            <!-- ── Colonne droite : Liste des fichiers ── -->
            <ListView Grid.Column="2"
                      x:Name="listViewFiles"
                      ItemsSource="{Binding CurrentChildren}"
                      SelectionMode="Extended"
                      SelectionChanged="ListView_SelectionChanged"
                      MouseDoubleClick="ListView_MouseDoubleClick"
                      VirtualizingStackPanel.IsVirtualizing="True"
                      VirtualizingStackPanel.VirtualizationMode="Recycling"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      Margin="0,0,4,4">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Width="260">
                            <GridViewColumn.Header>
                                <GridViewColumnHeader Content="Nom" Tag="Name"
                                                      Click="GridViewColumnHeader_Click"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="{Binding Icon}" Width="16" Height="16"
                                               Margin="0,0,4,0" VerticalAlignment="Center"
                                               RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Width="80">
                            <GridViewColumn.Header>
                                <GridViewColumnHeader Content="Type" Tag="NodeType"
                                                      Click="GridViewColumnHeader_Click"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding NodeType}" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Width="90">
                            <GridViewColumn.Header>
                                <GridViewColumnHeader Content="Taille" Tag="Size"
                                                      Click="GridViewColumnHeader_Click"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Size}" TextAlignment="Right"
                                               VerticalAlignment="Center"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Width="140">
                            <GridViewColumn.Header>
                                <GridViewColumnHeader Content="Modifié" Tag="DateModified"
                                                      Click="GridViewColumnHeader_Click"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DateModified,
                                                              StringFormat={}{0:dd/MM/yyyy HH:mm}}"
                                               VerticalAlignment="Center"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>

        <!-- ─────────────── ROW 3 : Barre inférieure ──────────────────── -->
        <Grid Grid.Row="3" Margin="4,4,4,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Fichier :"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>

            <TextBox Grid.Column="1"
                     IsReadOnly="True"
                     Text="{Binding SelectedFileName, Mode=OneWay}"
                     VerticalAlignment="Center"
                     Margin="0,0,8,0"
                     Padding="2"/>

            <Button Grid.Column="2"
                    Content="Ouvrir"
                    IsDefault="True"
                    IsEnabled="{Binding HasSelection}"
                    MinWidth="80"
                    Margin="0,0,4,0"
                    Click="BtnOpen_Click"/>

            <Button Grid.Column="3"
                    Content="Annuler"
                    IsCancel="True"
                    MinWidth="80"
                    Click="BtnCancel_Click"/>
        </Grid>
    </Grid>
</Window>
