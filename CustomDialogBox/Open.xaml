<Window x:Class="CustomDialogBox.Open"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CustomDialogBox"
        mc:Ignorable="d"
        Title="Ouvrir"
        Height="500"
        Width="800"
        MinHeight="300"
        MinWidth="500"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>

        <!-- Template hierarchique pour FileSystemNodeViewModel -->
        <HierarchicalDataTemplate DataType="{x:Type local:FileSystemNodeViewModel}"
                                  ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal">
                <Image Source="{Binding Icon}"
                       Width="16"
                       Height="16"
                       Margin="0,0,4,0"
                       VerticalAlignment="Center"
                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                <TextBlock Text="{Binding Name}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </HierarchicalDataTemplate>

        <!-- Style TreeViewItem avec bindings TwoWay IsExpanded / IsSelected -->
        <Style TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Zone principale TreeView + GridSplitter + ListView -->
            <RowDefinition Height="*"/>
            <!-- Separateur visuel (4 px — le GridSplitter colonne occupe deja l'espace
                 vertical, on n'ajoute pas de Separator supplementaire ici pour eviter
                 un artefact double-barre. La hauteur 4 sert uniquement d'espacement.) -->
            <RowDefinition Height="4"/>
            <!-- Barre inferieure fichier + boutons -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════
             ZONE PRINCIPALE : TreeView | GridSplitter | ListView
             ═══════════════════════════════════════════════════ -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="80"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*" MinWidth="150"/>
            </Grid.ColumnDefinitions>

            <!-- ─── TreeView arborescence ─── -->
            <TreeView x:Name="treeViewFolders"
                      Grid.Column="0"
                      ItemsSource="{Binding Drives}"
                      SelectedItemChanged="TreeView_SelectedItemChanged"
                      VirtualizingStackPanel.IsVirtualizing="True"
                      VirtualizingStackPanel.VirtualizationMode="Recycling"
                      Margin="4,4,0,4"/>

            <!-- ─── GridSplitter ─── -->
            <GridSplitter Grid.Column="1"
                          Width="4"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          ResizeBehavior="PreviousAndNext"
                          ResizeDirection="Columns"
                          Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"/>

            <!-- ─── ListView fichiers du dossier selectionne ─── -->
            <ListView x:Name="listViewFiles"
                      Grid.Column="2"
                      ItemsSource="{Binding CurrentChildren}"
                      SelectionChanged="ListView_SelectionChanged"
                      MouseDoubleClick="ListView_MouseDoubleClick"
                      VirtualizingStackPanel.IsVirtualizing="True"
                      VirtualizingStackPanel.VirtualizationMode="Recycling"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      Margin="0,4,4,4">

                <ListView.View>
                    <GridView>

                        <!-- Colonne Nom : icone + label — largeur extensible (Width="*")
                             pour que la colonne remplisse l'espace disponible
                             quand la fenetre est redimensionnee. -->
                        <GridViewColumn Width="260">
                            <GridViewColumn.Header>
                                <GridViewColumnHeader Content="Nom"
                                                      Tag="Name"
                                                      Click="GridViewColumnHeader_Click"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="{Binding Icon}"
                                               Width="16"
                                               Height="16"
                                               Margin="0,0,4,0"
                                               VerticalAlignment="Center"
                                               RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                        <TextBlock Text="{Binding Name}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Colonne Type -->
                        <GridViewColumn Width="120">
                            <GridViewColumn.Header>
                                <GridViewColumnHeader Content="Type"
                                                      Tag="NodeType"
                                                      Click="GridViewColumnHeader_Click"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding NodeType}" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Colonne Taille (avec unite Ko) -->
                        <GridViewColumn Width="90">
                            <GridViewColumn.Header>
                                <GridViewColumnHeader Content="Taille (Ko)"
                                                      Tag="Size"
                                                      Click="GridViewColumnHeader_Click"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Size}" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Colonne Date de modification (accent corrige) -->
                        <GridViewColumn Width="140">
                            <GridViewColumn.Header>
                                <GridViewColumnHeader Content="Modifié"
                                                      Tag="DateModified"
                                                      Click="GridViewColumnHeader_Click"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DateModified, StringFormat={}{0:dd/MM/yyyy HH:mm}}"
                                               VerticalAlignment="Center"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                    </GridView>
                </ListView.View>

            </ListView>

        </Grid>

        <!-- Row 1 : espace pur (4 px) — pas de Separator pour eviter l'artefact
             double-barre avec le GridSplitter colonne deja present au-dessus. -->

        <!-- ═══════════════════════════════════════════════════
             BARRE INFERIEURE : Fichier | TextBox | Ouvrir | Annuler
             ═══════════════════════════════════════════════════ -->
        <Grid Grid.Row="2"
              Margin="4,6,4,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Label "Fichier :" -->
            <TextBlock Grid.Column="0"
                       Text="Fichier :"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>

            <!-- Nom du fichier selectionne, lecture seule, lie au ViewModel -->
            <TextBox Grid.Column="1"
                     IsReadOnly="True"
                     Text="{Binding SelectedFileName, Mode=OneWay}"
                     VerticalAlignment="Center"
                     Margin="0,0,8,0"
                     Padding="2"/>

            <!-- Bouton Ouvrir : defaut, active seulement si selection -->
            <Button Grid.Column="2"
                    Content="Ouvrir"
                    IsDefault="True"
                    IsEnabled="{Binding HasSelection}"
                    MinWidth="80"
                    Margin="0,0,4,0"
                    Click="BtnOpen_Click"/>

            <!-- Bouton Annuler : ferme la fenetre sans resultat -->
            <Button Grid.Column="3"
                    Content="Annuler"
                    IsCancel="True"
                    MinWidth="80"
                    Click="BtnCancel_Click"/>

        </Grid>

    </Grid>

</Window>
